APP_NAME=LavaSMSID
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Asia/Makassar

APP_PORT=8080
MYSQL_PORT=33066

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=lavasmsid
DB_USERNAME=lavasmsid
DB_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
FILESYSTEM_DISK=public

MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME_SMTP_USERNAME
MAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.example
MAIL_FROM_NAME="${APP_NAME}"
